 api/transactions.go | 35 ++++++++++++++++++++++-------------
 cmd/login.go        | 40 +++++++++++++++++++++++++++++-----------
 ledger/parser.go    | 10 +++++++---
 4 files changed, 59 insertions(+), 27 deletions(-)

